; Distribution-shift problem p18_test
; Cities: 4, Packages: 6, Trucks: 3, Topology: chain
(define (problem p18_test)
  (:domain distribution-shift)
  (:objects
    city0 city1 city2 city3 - city
    loc0_0 loc0_1 loc0_2 loc0_3 loc1_0 loc1_1 loc1_2 loc1_3 loc2_0 loc2_1 loc2_2 loc2_3 loc2_4 loc3_0 loc3_1 loc3_2 loc3_3 - location
    truck0 truck1 truck2 - truck
    pkg0 pkg1 pkg2 pkg3 pkg4 pkg5 - package)
  (:init
    (in-city loc0_0 city0)
    (in-city loc0_1 city0)
    (in-city loc0_2 city0)
    (in-city loc0_3 city0)
    (in-city loc1_0 city1)
    (in-city loc1_1 city1)
    (in-city loc1_2 city1)
    (in-city loc1_3 city1)
    (in-city loc2_0 city2)
    (in-city loc2_1 city2)
    (in-city loc2_2 city2)
    (in-city loc2_3 city2)
    (in-city loc2_4 city2)
    (in-city loc3_0 city3)
    (in-city loc3_1 city3)
    (in-city loc3_2 city3)
    (in-city loc3_3 city3)
    (adjacent loc0_0 loc0_1)
    (adjacent loc0_1 loc0_0)
    (adjacent loc0_1 loc0_2)
    (adjacent loc0_2 loc0_1)
    (adjacent loc0_2 loc0_3)
    (adjacent loc0_3 loc0_2)
    (adjacent loc1_0 loc1_1)
    (adjacent loc1_1 loc1_0)
    (adjacent loc1_1 loc1_2)
    (adjacent loc1_2 loc1_1)
    (adjacent loc1_2 loc1_3)
    (adjacent loc1_3 loc1_2)
    (adjacent loc2_0 loc2_1)
    (adjacent loc2_1 loc2_0)
    (adjacent loc2_1 loc2_2)
    (adjacent loc2_2 loc2_1)
    (adjacent loc2_2 loc2_3)
    (adjacent loc2_3 loc2_2)
    (adjacent loc2_3 loc2_4)
    (adjacent loc2_4 loc2_3)
    (adjacent loc3_0 loc3_1)
    (adjacent loc3_1 loc3_0)
    (adjacent loc3_1 loc3_2)
    (adjacent loc3_2 loc3_1)
    (adjacent loc3_2 loc3_3)
    (adjacent loc3_3 loc3_2)
    (congested loc2_2)
    (congested loc2_4)
    (congested loc3_1)
    (congested loc3_3)
    (at-truck truck0 loc0_0)
    (at-truck truck1 loc1_0)
    (at-truck truck2 loc2_0)
    (at-package pkg0 loc2_1)
    (at-package pkg1 loc1_0)
    (at-package pkg2 loc3_3)
    (at-package pkg3 loc0_1)
    (at-package pkg4 loc0_3)
    (at-package pkg5 loc2_1)
    (= (total-cost) 0))
  (:goal (and (at-package pkg0 loc1_0)
             (at-package pkg1 loc2_0)
             (at-package pkg2 loc3_0)
             (at-package pkg3 loc0_0)
             (at-package pkg4 loc1_0)
             (at-package pkg5 loc2_0)))
  (:metric minimize (total-cost))
)
